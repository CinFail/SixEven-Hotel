<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="hotel.ui.RegisterController"
            fitToWidth="true"
            fitToHeight="true"
            style="-fx-background-color: #1a1a2e; -fx-background: #1a1a2e;">

    <StackPane style="-fx-background-color: #1a1a2e;">

        <VBox alignment="CENTER"
              spacing="12"
              maxWidth="480"
              style="-fx-background-color: #1a1a2e; -fx-padding: 30 50 30 50;">

            <Label text="🏨" style="-fx-font-size: 40px;"/>
            <Label text="Create Account"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

            <!-- Full Name -->
            <VBox spacing="4">
                <Label text="Full Name *" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                <TextField fx:id="nameField"
                           style="-fx-background-color:#16213e;-fx-text-fill:white;
                                  -fx-border-color:#444;-fx-border-radius:5;-fx-background-radius:5;
                                  -fx-padding:8;-fx-font-size:13px;"/>
            </VBox>

            <!-- Username -->
            <VBox spacing="4">
                <Label text="Username *" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                <TextField fx:id="usernameField"
                           style="-fx-background-color:#16213e;-fx-text-fill:white;
                                  -fx-border-color:#444;-fx-border-radius:5;-fx-background-radius:5;
                                  -fx-padding:8;-fx-font-size:13px;"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="4">
                <Label text="Password * (min 6 characters)" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                <PasswordField fx:id="passwordField"
                               style="-fx-background-color:#16213e;-fx-text-fill:white;
                                      -fx-border-color:#444;-fx-border-radius:5;-fx-background-radius:5;
                                      -fx-padding:8;-fx-font-size:13px;"/>
            </VBox>

            <!-- Email -->
            <VBox spacing="4">
                <Label text="Email" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                <TextField fx:id="emailField"
                           style="-fx-background-color:#16213e;-fx-text-fill:white;
                                  -fx-border-color:#444;-fx-border-radius:5;-fx-background-radius:5;
                                  -fx-padding:8;-fx-font-size:13px;"/>
            </VBox>

            <!-- Phone -->
            <VBox spacing="4">
                <Label text="Phone" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                <TextField fx:id="phoneField"
                           style="-fx-background-color:#16213e;-fx-text-fill:white;
                                  -fx-border-color:#444;-fx-border-radius:5;-fx-background-radius:5;
                                  -fx-padding:8;-fx-font-size:13px;"/>
            </VBox>

            <!-- Address -->
            <VBox spacing="4">
                <Label text="Address" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                <TextField fx:id="addressField"
                           style="-fx-background-color:#16213e;-fx-text-fill:white;
                                  -fx-border-color:#444;-fx-border-radius:5;-fx-background-radius:5;
                                  -fx-padding:8;-fx-font-size:13px;"/>
            </VBox>

            <!-- Government ID Row -->
            <HBox spacing="10">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="ID Type" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                    <ComboBox fx:id="idTypeCombo" prefWidth="160"
                              style="-fx-background-color:#16213e;-fx-text-fill:white;
                                     -fx-border-color:#444;-fx-border-radius:5;-fx-background-radius:5;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="ID Number" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                    <TextField fx:id="idNumberField"
                               style="-fx-background-color:#16213e;-fx-text-fill:white;
                                      -fx-border-color:#444;-fx-border-radius:5;-fx-background-radius:5;
                                      -fx-padding:8;-fx-font-size:13px;"/>
                </VBox>
            </HBox>

            <Label fx:id="messageLabel"
                   style="-fx-font-size: 12px;"
                   visible="false" wrapText="true"/>

            <Button text="Create Account"
                    onAction="#handleRegister"
                    prefWidth="380"
                    style="-fx-background-color:#e94560;-fx-text-fill:white;
                           -fx-font-size:14px;-fx-font-weight:bold;
                           -fx-background-radius:5;-fx-padding:10;-fx-cursor:hand;"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Already have an account?" style="-fx-text-fill:#aaaaaa;-fx-font-size:12px;"/>
                <Hyperlink text="Back to Login"
                           onAction="#handleBack"
                           style="-fx-text-fill:#e94560;-fx-font-size:12px;"/>
            </HBox>

        </VBox>

    </StackPane>

</ScrollPane>
