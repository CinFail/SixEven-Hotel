<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="hotel.ui.LoginController"
      alignment="CENTER"
      spacing="15"
      prefWidth="400" prefHeight="500"
      style="-fx-background-color: #1a1a2e;">

    <padding><Insets top="40" right="50" bottom="40" left="50"/></padding>

    <Label text="🏨" style="-fx-font-size: 52px;"/>

    <Label text="Hotel Reservation System"
           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Label text="Sign in to your account"
           style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;"/>

    <VBox spacing="5" style="-fx-padding: 15 0 0 0;">
        <Label text="Username" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
        <TextField fx:id="usernameField"
                   promptText="Enter username"
                   style="-fx-background-color: #16213e; -fx-text-fill: white;
                          -fx-border-color: #444; -fx-border-radius: 5; -fx-background-radius: 5;
                          -fx-padding: 8; -fx-font-size: 13px;"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Password" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
        <PasswordField fx:id="passwordField"
                       promptText="Enter password"
                       style="-fx-background-color: #16213e; -fx-text-fill: white;
                              -fx-border-color: #444; -fx-border-radius: 5; -fx-background-radius: 5;
                              -fx-padding: 8; -fx-font-size: 13px;"/>
    </VBox>

    <Label fx:id="errorLabel"
           style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"
           visible="false"/>

    <Button text="Login"
            onAction="#handleLogin"
            prefWidth="300"
            style="-fx-background-color: #e94560; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 5; -fx-padding: 10;
                   -fx-cursor: hand;"/>

    <Separator style="-fx-background-color: #333;"/>

    <HBox alignment="CENTER" spacing="5">
        <Label text="No account?" style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;"/>
        <Hyperlink text="Register here"
                   onAction="#handleGoToRegister"
                   style="-fx-text-fill: #e94560; -fx-font-size: 12px;"/>
    </HBox>

</VBox>
